# ============================================================
# AgriAI Backend — Development Environment
# ============================================================
# Copy to: backend/.env
# See .env.example for full reference and documentation.

ENVIRONMENT=development

# Database — use SQLite for local dev (zero setup) or PostgreSQL via Docker
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agri_ai

# Redis (optional locally, required via Docker)
REDIS_URL=redis://:agriai_redis_dev_pass@localhost:6379/0
REDIS_PASSWORD=agriai_redis_dev_pass
CACHE_ENABLED=true

# Security — dev-only key; generate a real one for staging/production
SECRET_KEY=dev-insecure-key-for-local-development-only-must-be-32plus-chars

# AI Providers
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# External APIs
OPENWEATHER_API_KEY=your-openweather-api-key
DATA_GOV_IN_API_KEY=

# Email
EMAIL_ENABLED=false
SENDGRID_API_KEY=
SMTP_FROM_EMAIL=noreply@localhost
SMTP_FROM_NAME=AgriAI Platform

# SMS
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# OAuth — Google Login
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# CORS
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Cookie auth
COOKIE_DOMAIN=
COOKIE_SAMESITE=lax
COOKIE_SECURE=false

# Error Tracking
SENTRY_DSN=
SENTRY_ENV=development
SENTRY_TRACES_SAMPLE_RATE=0.0
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_PII=false

# Proxy
FORWARDED_ALLOW_IPS=127.0.0.1

# Docs
ENABLE_DOCS=true

# Anonymous error logging
ALLOW_ANON_ERRORS=true

# Superuser bootstrap
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=admin123
SUPERUSER_FULL_NAME=Dev Admin

# Backup
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agri_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
BACKUP_DIR=./backend/backups
KEEP_BACKUPS=7
