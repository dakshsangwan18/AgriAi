# ============================================================
# AgriAI Backend — Environment Configuration Reference
# ============================================================
# Copy this file to .env and fill in your values.
# NEVER commit a real .env file to version control.
#
# Generate a secure SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================

# === Environment ===
# development | staging | production
ENVIRONMENT=development

# === Database ===
# PostgreSQL (production): postgresql://user:password@host:5432/dbname
# SQLite (development only): sqlite:///./agri_ai.db
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/agri_ai

# === Redis Cache ===
REDIS_URL=redis://:redis_password@localhost:6379/0
REDIS_PASSWORD=changeme
CACHE_ENABLED=true

# === Security ===
# Minimum 64 characters. Must be cryptographically random.
# In production, patterns like "replace", "secret", "change-me" will be rejected.
SECRET_KEY=generate-a-secure-64-char-key-using-python-secrets-token-urlsafe
# Defaults shown; uncomment to override:
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=14

# === Cookie Auth ===
# ACCESS_TOKEN_COOKIE_NAME=access_token
# REFRESH_TOKEN_COOKIE_NAME=refresh_token
# CSRF_COOKIE_NAME=csrf_token
# CSRF_HEADER_NAME=X-CSRF-Token
# Only needed in production behind a custom domain:
# COOKIE_DOMAIN=
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=false

# === AI Provider API Keys ===
# Gemini — AI Crop Advisor (https://aistudio.google.com/app/apikey)
GEMINI_API_KEY=your-gemini-api-key
# Groq — Farmer Chatbot (https://console.groq.com/keys)
GROQ_API_KEY=your-groq-api-key

# === External APIs ===
# OpenWeatherMap (https://openweathermap.org/api)
OPENWEATHER_API_KEY=your-openweather-api-key
# Data.gov.in — real Indian market price data
DATA_GOV_IN_API_KEY=your-data-gov-in-api-key

# === Email (optional) ===
# Set EMAIL_ENABLED=true when configured
EMAIL_ENABLED=false
# Method 1: SendGrid (https://sendgrid.com — 100 free emails/day)
SENDGRID_API_KEY=your-sendgrid-api-key
# Method 2: SMTP (Gmail requires App Password)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AgriAI Platform

# === SMS / WhatsApp (optional) ===
# TWILIO_ACCOUNT_SID=your-twilio-account-sid
# TWILIO_AUTH_TOKEN=your-twilio-auth-token
# TWILIO_PHONE_NUMBER=+1234567890

# === OAuth — Google Login ===
# Get credentials: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
# Must match the authorized redirect URI in Google Cloud Console
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# === CORS ===
FRONTEND_URL=http://localhost:5173
# Comma-separated list for production (overrides FRONTEND_URL + dev defaults):
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# === Proxy ===
# FORWARDED_ALLOW_IPS=127.0.0.1,10.0.0.0/8

# === Request Limits ===
# MAX_REQUEST_SIZE_MB=10

# === API Docs ===
# Disabled by default in production; uncomment to force:
# ENABLE_DOCS=true

# === Error Tracking (Sentry) ===
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENV=production
# SENTRY_RELEASE=agriai@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_SEND_PII=false

# === Anonymous Error Logging ===
# Disabled by default in production:
# ALLOW_ANON_ERRORS=false
# ANON_ERROR_RATE_LIMIT=10/minute

# === Content Security Policy ===
# CSP_REPORT_ONLY=true
# CSP_REPORT_URI=https://csp-report.example.com/report
# CSP_CONNECT_SRC=https://api.example.com

# === Superuser Bootstrap ===
# Used by scripts/create_superuser.py for initial admin account
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=replace-with-strong-password
SUPERUSER_FULL_NAME=Platform Administrator

# === Docker/Deployment ===
# Used by backup-db.sh and restore-db.sh:
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# POSTGRES_DB=agri_ai
# POSTGRES_USER=postgres
# POSTGRES_PASSWORD=postgres
# BACKUP_DIR=./backend/backups
# KEEP_BACKUPS=7
