# ===================================
# AI Provider API Keys
# ===================================

# Gemini API - Used for AI Crop Advisor
# Get key from: https://aistudio.google.com/app/apikey
# Limits: 500 RPD (free tier with gemini-2.5-flash)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API - Used for Farmer Chatbot (RECOMMENDED)
# Get key from: https://console.groq.com/keys
# Limits: 30 RPM, 14,400 RPD (free tier - best value!)
GROQ_API_KEY=your_groq_api_key_here

# ===================================
# External API Keys
# ===================================

# Get OpenWeather API key from: https://openweathermap.org/api
OPENWEATHER_API_KEY=your_openweather_api_key_here

# Optional: Data.gov.in API for real market data
DATA_GOV_IN_API_KEY=your_data_gov_in_api_key_here

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agridb

# ====================================================================
# 🔐 CRITICAL: SECRET_KEY (REQUIRED - NO DEFAULT ALLOWED)
# ====================================================================
# This key is used to sign JWT tokens. It MUST be cryptographically secure!
#
# ⚠️  SECURITY REQUIREMENTS:
# - Minimum 32 characters (64+ recommended)
# - Cryptographically random (use secrets module)
# - Different key for EACH environment (dev, staging, production)
# - NEVER commit the actual key to git
# - Rotate regularly (every 90 days in production)
#
# 🔧 GENERATE A SECURE KEY:
# Method 1: Use our helper script (recommended)
#   python scripts/generate_secret.py
#
# Method 2: Generate manually
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
#
# Method 3: Use online tool (less secure)
#   https://generate-secret.vercel.app/64
#
# 📋 EXAMPLE (DO NOT USE THIS VALUE):
#   SECRET_KEY=xK7vR9pL2mN8qT5wE3fG1hJ4kP6sV9yB2nM5lQ8rT1wA3dG6jK9pS2vY5zC
#
# ✅ Your SECRET_KEY:
SECRET_KEY=YOUR_GENERATED_SECRET_KEY_REPLACE_THIS_NOW
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Email Configuration
# Choose ONE method: SendGrid OR SMTP

# Method 1: SendGrid (Recommended for production)
# Get free API key at: https://sendgrid.com (100 emails/day free)
EMAIL_ENABLED=false
SENDGRID_API_KEY=your_sendgrid_api_key_here

# Method 2: SMTP (Gmail, Outlook, Custom SMTP)
# For Gmail: Use App Password (not your regular password)
# Guide: https://support.google.com/accounts/answer/185833
# EMAIL_ENABLED=false
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password-here
# SMTP_FROM_EMAIL=your-email@gmail.com
# SMTP_FROM_NAME=AgriAI Platform

# CORS
FRONTEND_URL=http://localhost:5173
# Optional: comma-separated list of allowed origins (overrides defaults)
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# OAuth - Google Login
# Get credentials at: https://console.cloud.google.com/apis/credentials
# 1. Create OAuth 2.0 Client ID
# 2. Add Authorized redirect URI: http://localhost:5173/auth/google/success
# 3. Copy Client ID and Secret below
GOOGLE_CLIENT_ID=your_google_client_id_here
GOOGLE_CLIENT_SECRET=your_google_client_secret_here
GOOGLE_REDIRECT_URI=http://localhost:5173/auth/google/callback

# Superuser bootstrap (optional, for scripts/create_superuser.py)
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=replace-with-strong-password
SUPERUSER_FULL_NAME=Platform Administrator

# Environment
ENVIRONMENT=development

# Cookie auth
# ACCESS_TOKEN_COOKIE_NAME=access_token
# REFRESH_TOKEN_COOKIE_NAME=refresh_token
# CSRF_COOKIE_NAME=csrf_token
# CSRF_HEADER_NAME=X-CSRF-Token
# COOKIE_DOMAIN=.example.com
# COOKIE_SAMESITE=none
# COOKIE_SECURE=true
# REFRESH_TOKEN_EXPIRE_DAYS=14

# Trusted proxy IPs for X-Forwarded-* (set to your reverse proxy IPs or CIDR)
# FORWARDED_ALLOW_IPS=127.0.0.1,10.0.0.0/8

# Anonymous error logging (disabled by default in production)
# ALLOW_ANON_ERRORS=false
# ANON_ERROR_RATE_LIMIT=10/minute

# Docs exposure (disable in production by default)
# ENABLE_DOCS=true

# CSP controls
# CSP_REPORT_ONLY=true
# CSP_REPORT_URI=https://csp-report.example.com/report
# CSP_CONNECT_SRC=https://api.example.com

# Sentry
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENV=production
# SENTRY_RELEASE=agriai@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_SEND_PII=false
