# ============================================================
# AgriAI Backend — Environment Configuration
# ============================================================
# Copy this file to backend/.env and fill in your values.
# NEVER commit a real .env to version control.
#
# Generate a secure SECRET_KEY:
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================

# === Environment ===
# development | staging | production
ENVIRONMENT=development

# === Database ===
# PostgreSQL: postgresql://user:password@host:5432/dbname
# SQLite (dev only): sqlite:///./agri_ai.db
DATABASE_URL=postgresql://postgres:changeme@localhost:5432/agri_ai

# === Redis Cache ===
# Docker:  redis://:agriai_redis_dev_pass@redis:6379/0
# Local:   redis://:your_password@localhost:6379/0
REDIS_URL=redis://:changeme@localhost:6379/0
REDIS_PASSWORD=changeme
CACHE_ENABLED=true

# === Security ===
# CRITICAL: Must be >=32 chars. Production rejects insecure patterns.
# Dev (ok):      dev-insecure-key-for-local-development-only-32plus
# Production:    generate a unique 64-char random key (see top of file)
SECRET_KEY=dev-insecure-key-for-local-development-only-must-be-32plus

# === AI API Keys ===
GEMINI_API_KEY=your-gemini-api-key       # https://aistudio.google.com/app/apikey
GROQ_API_KEY=your-groq-api-key           # https://console.groq.com/keys

# === External APIs ===
OPENWEATHER_API_KEY=your-openweather-key  # https://openweathermap.org/api
DATA_GOV_IN_API_KEY=                      # Real Indian market data (optional)

# === Email (optional) ===
# Set EMAIL_ENABLED=true when configured. Supports SendGrid or SMTP.
EMAIL_ENABLED=false
SENDGRID_API_KEY=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AgriAI Platform
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASSWORD=your-app-password

# === SMS / WhatsApp (optional) ===
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_PHONE_NUMBER=

# === OAuth — Google Login ===
# Get credentials at https://console.cloud.google.com/apis/credentials
# Authorized redirect: YOUR_FRONTEND_URL + /api/v1/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# === CORS ===
# Dev:    http://localhost:5173
# Prod:   https://app.yourdomain.com
FRONTEND_URL=http://localhost:5173
# Production (comma-separated):
# CORS_ORIGINS=https://app.example.com,https://admin.example.com

# === Cookie Auth ===
# Dev defaults shown. For production behind custom domain:
#   COOKIE_DOMAIN=.yourdomain.com
#   COOKIE_SAMESITE=none
#   COOKIE_SECURE=true
# COOKIE_DOMAIN=
# COOKIE_SAMESITE=lax
# COOKIE_SECURE=false

# === Security Defaults (uncomment to override) ===
# ALGORITHM=HS256
# ACCESS_TOKEN_EXPIRE_MINUTES=15
# REFRESH_TOKEN_EXPIRE_DAYS=14
# ACCESS_TOKEN_COOKIE_NAME=access_token
# REFRESH_TOKEN_COOKIE_NAME=refresh_token
# CSRF_COOKIE_NAME=csrf_token
# CSRF_HEADER_NAME=X-CSRF-Token
# FORWARDED_ALLOW_IPS=127.0.0.1,10.0.0.0/8
# MAX_REQUEST_SIZE_MB=10
# ENABLE_DOCS=true         # auto-disabled in production
# ALLOW_ANON_ERRORS=true   # auto-disabled in production

# === Error Tracking (Sentry) ===
# SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# SENTRY_ENV=production
# SENTRY_RELEASE=agriai@1.0.0
# SENTRY_TRACES_SAMPLE_RATE=0.05
# SENTRY_PROFILES_SAMPLE_RATE=0.0
# SENTRY_SEND_PII=false

# === Superuser Bootstrap ===
# Used by scripts/create_superuser.py
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=admin123
SUPERUSER_FULL_NAME=Platform Administrator

# === Docker / Backups ===
# Used by backup-db.sh and restore-db.sh:
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agri_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
BACKUP_DIR=./backend/backups
KEEP_BACKUPS=7
