# App
ENVIRONMENT=development

# Database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/agri_ai

# Redis
REDIS_URL=redis://:agriai_redis_dev_pass@localhost:6379/0
REDIS_PASSWORD=agriai_redis_dev_pass
CACHE_ENABLED=true

# Security
SECRET_KEY=
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# AI
GEMINI_API_KEY=
GROQ_API_KEY=

# External APIs
OPENWEATHER_API_KEY=
DATA_GOV_IN_API_KEY=

# Email
EMAIL_ENABLED=false
SENDGRID_API_KEY=
SMTP_FROM_EMAIL=noreply@example.com
SMTP_FROM_NAME=AgriAI

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# Frontend
FRONTEND_URL=http://localhost:5173

# Cookie settings
# In production, ENVIRONMENT=production makes cookies Secure; SameSite=None automatically.
# Set COOKIE_DOMAIN if frontend and backend are on different subdomains.
# COOKIE_DOMAIN=
# COOKIE_SAMESITE=
# COOKIE_SECURE=

# Superuser
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=admin123
SUPERUSER_FULL_NAME=Platform Administrator

# Backups
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=agri_ai
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
BACKUP_DIR=./backend/backups
KEEP_BACKUPS=7