# ============================================================
# AgriAI Backend — Production Environment
# ============================================================
# Copy to: backend/.env.production or set as server env vars.
# See .env.example for full reference and documentation.
#
# CRITICAL: Use a strong, unique SECRET_KEY for production.
#   python -c "import secrets; print(secrets.token_urlsafe(64))"
# ============================================================

ENVIRONMENT=production

DATABASE_URL=postgresql://agri_user:STRONG_DB_PASSWORD@prod-db.internal:5432/agri_ai

REDIS_URL=redis://:STRONG_REDIS_PASSWORD@prod-redis.internal:6379/0
REDIS_PASSWORD=STRONG_REDIS_PASSWORD
CACHE_ENABLED=true

SECRET_KEY=generate-a-unique-cryptographically-random-64-character-key-for-production

GEMINI_API_KEY=your-production-gemini-api-key
GROQ_API_KEY=your-production-groq-api-key

OPENWEATHER_API_KEY=your-production-openweather-api-key
DATA_GOV_IN_API_KEY=your-production-data-gov-in-api-key

EMAIL_ENABLED=true
SENDGRID_API_KEY=your-production-sendgrid-api-key
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AgriAI

TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

GOOGLE_CLIENT_ID=your-production-google-client-id
GOOGLE_CLIENT_SECRET=your-production-google-client-secret
GOOGLE_REDIRECT_URI=https://app.yourdomain.com/api/v1/auth/google/callback

FRONTEND_URL=https://app.yourdomain.com
CORS_ORIGINS=https://app.yourdomain.com,https://admin.yourdomain.com

COOKIE_DOMAIN=.yourdomain.com
COOKIE_SAMESITE=none
COOKIE_SECURE=true

SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENV=production
SENTRY_RELEASE=agriai@1.0.0
SENTRY_TRACES_SAMPLE_RATE=0.05
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_PII=false

FORWARDED_ALLOW_IPS=127.0.0.1,10.0.0.0/8

ENABLE_DOCS=false

ALLOW_ANON_ERRORS=false

SUPERUSER_EMAIL=admin@yourdomain.com
SUPERUSER_PASSWORD=strong-admin-password
SUPERUSER_FULL_NAME=Platform Administrator

POSTGRES_HOST=prod-db.internal
POSTGRES_PORT=5432
POSTGRES_DB=agri_ai
POSTGRES_USER=agri_user
POSTGRES_PASSWORD=STRONG_DB_PASSWORD
BACKUP_DIR=/var/backups/agriai
KEEP_BACKUPS=90
