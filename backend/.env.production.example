ENVIRONMENT=production
DATABASE_URL=postgresql://user:password@prod-db:5432/agri_ai
SECRET_KEY=replace-with-a-secure-secret
OPENWEATHER_API_KEY=your-openweather-key
GEMINI_API_KEY=your-gemini-key
