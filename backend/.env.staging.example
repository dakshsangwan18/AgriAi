# ============================================================
# AgriAI Backend — Staging Environment
# ============================================================
# Copy to: backend/.env.staging
# See .env.example for full reference and documentation.

ENVIRONMENT=staging

DATABASE_URL=postgresql://agri_user:strong_password@staging-db.internal:5432/agri_ai

REDIS_URL=redis://:redis_staging_pass@staging-redis.internal:6379/0
REDIS_PASSWORD=redis_staging_pass
CACHE_ENABLED=true

SECRET_KEY=generate-a-secure-64-char-key-using-secrets-token-urlsafe

GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

OPENWEATHER_API_KEY=your-openweather-api-key
DATA_GOV_IN_API_KEY=your-data-gov-in-api-key

EMAIL_ENABLED=true
SENDGRID_API_KEY=your-sendgrid-api-key
SMTP_FROM_EMAIL=noreply@staging.yourdomain.com
SMTP_FROM_NAME=AgriAI Staging

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=https://staging.example.com/api/v1/auth/google/callback

FRONTEND_URL=https://staging.example.com
CORS_ORIGINS=https://staging.example.com

COOKIE_DOMAIN=.example.com
COOKIE_SAMESITE=none
COOKIE_SECURE=true

SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
SENTRY_ENV=staging
SENTRY_TRACES_SAMPLE_RATE=0.1
SENTRY_PROFILES_SAMPLE_RATE=0.0
SENTRY_SEND_PII=false

FORWARDED_ALLOW_IPS=127.0.0.1,10.0.0.0/8

ENABLE_DOCS=false

ALLOW_ANON_ERRORS=false

SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=strong-admin-password
SUPERUSER_FULL_NAME=Staging Admin

POSTGRES_HOST=staging-db.internal
POSTGRES_PORT=5432
POSTGRES_DB=agri_ai
POSTGRES_USER=agri_user
POSTGRES_PASSWORD=strong_password
BACKUP_DIR=./backend/backups
KEEP_BACKUPS=30
