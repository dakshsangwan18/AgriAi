# ============================================================
# AgriAI Frontend — Environment Configuration
# ============================================================
# Copy this file to frontend/.env and fill in your values.
# Vite only exposes VITE_-prefixed variables to client code.
# NEVER put real secrets here — they become public in the bundle.
# ============================================================

# === API ===
# Dev:     http://localhost:8000
# Docker:  http://localhost:8000
# Prod:    https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# === Environment ===
# development | staging | production
VITE_ENVIRONMENT=development

# === Error Tracking (Sentry) ===
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# VITE_SENTRY_ENV=production
# VITE_SENTRY_RELEASE=agriai@1.0.0
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
# VITE_SENTRY_PROFILES_SAMPLE_RATE=0.0

# === Feature Flags ===
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG_MODE=false
