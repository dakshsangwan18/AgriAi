# ============================================================
# AgriAI Frontend — Environment Configuration Reference
# ============================================================
# Copy this file to .env and fill in your values.
# Vite only exposes variables prefixed with VITE_ to the client.
# NEVER commit real keys or secrets here — they become public.

# === API Configuration ===
# Development: http://localhost:8000
# Docker dev:   http://localhost:8000
# Production:    https://api.yourdomain.com
VITE_API_BASE_URL=http://localhost:8000

# === Environment ===
# development | staging | production
VITE_ENVIRONMENT=development

# === Error Tracking (Sentry) ===
# VITE_SENTRY_DSN=https://examplePublicKey@o0.ingest.sentry.io/0
# VITE_SENTRY_ENV=production
# VITE_SENTRY_RELEASE=agriai@1.0.0
# VITE_SENTRY_TRACES_SAMPLE_RATE=0.05
# VITE_SENTRY_PROFILES_SAMPLE_RATE=0.0

# === Feature Flags ===
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG_MODE=false

# === Branding ===
# VITE_APP_NAME=AgriAI Platform
# VITE_APP_VERSION=1.0.0
