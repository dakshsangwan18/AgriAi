# Frontend Environment

# API URL
# Leave unset in local development to use the Vite dev proxy (/api -> http://localhost:8000).
# This makes the frontend and backend same-origin so cookie-based auth works.
# Set this explicitly for production or when testing against a deployed backend.
# VITE_API_BASE_URL=http://localhost:8000

# Environment
VITE_ENVIRONMENT=development

# Optional: Sentry
# VITE_SENTRY_DSN=
# VITE_SENTRY_ENV=production
# VITE_SENTRY_RELEASE=agriai@1.0.0

# Optional: Feature Flags
# VITE_ENABLE_ANALYTICS=false
# VITE_ENABLE_DEBUG_MODE=false