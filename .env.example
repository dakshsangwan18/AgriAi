# ============================================================
# AgriAI — Docker / Root Environment Configuration
# ============================================================
# Copy to .env in the project root for Docker Compose.
# Docker Compose automatically loads this file.
#
# For individual service config, see:
#   backend/.env.example    — all backend app variables
#   frontend/.env.example   — all frontend build-time variables
# ============================================================

# === Environment ===
# development | staging | production
ENVIRONMENT=development
FORWARDED_ALLOW_IPS=127.0.0.1
CACHE_ENABLED=true

# === Database (PostgreSQL) ===
POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agri_ai

# === Redis ===
# Production: use a strong password
REDIS_PASSWORD=agriai_redis_dev_pass

# === Security ===
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
SECRET_KEY=dev-insecure-key-for-local-development-only-must-be-32plus

# === AI API Keys ===
GEMINI_API_KEY=your-gemini-api-key
GROQ_API_KEY=your-groq-api-key

# === External APIs ===
OPENWEATHER_API_KEY=your-openweather-api-key
DATA_GOV_IN_API_KEY=

# === Email (optional) ===
SENDGRID_API_KEY=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AgriAI Platform

# === SMS (optional) ===
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# === OAuth — Google Login ===
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

# === CORS ===
FRONTEND_URL=http://localhost
# CORS_ORIGINS=https://app.example.com,https://admin.example.com
