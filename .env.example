ENVIRONMENT=development
FORWARDED_ALLOW_IPS=127.0.0.1
CACHE_ENABLED=true

POSTGRES_USER=postgres
POSTGRES_PASSWORD=changeme
POSTGRES_DB=agri_ai

REDIS_PASSWORD=agriai_redis_dev_pass

SECRET_KEY=dev-insecure-key-for-local-development-only

GEMINI_API_KEY=
GROQ_API_KEY=

OPENWEATHER_API_KEY=
DATA_GOV_IN_API_KEY=

SENDGRID_API_KEY=
SMTP_FROM_EMAIL=noreply@yourdomain.com
SMTP_FROM_NAME=AgriAI

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Must match exactly what is configured in Google Cloud Console.
# Local dev: backend callback directly (OAuth redirect cannot go through Vite proxy).
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback

FRONTEND_URL=http://localhost

# Cookie settings for cross-origin / subdomain deployments.
# In production, set ENVIRONMENT=production so cookies become Secure; SameSite=None.
# If frontend and backend are on different subdomains (e.g., app.example.com / api.example.com),
# set COOKIE_DOMAIN=.example.com so the auth cookies are shared.
# COOKIE_DOMAIN=
# COOKIE_SAMESITE=
# COOKIE_SECURE=